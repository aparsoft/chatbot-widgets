{
  "name": "@aparsoft/chatbot-vue",
  "version": "1.0.0",
  "description": "Vue component for the Aparsoft AI Chatbot Widget -- works with Vue 2.7+ and Vue 3, SSR-safe.",
  "main": "src/AparsoftChatbot.vue",
